{
  "name": "mern-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Mehdi Msallem — MERN-stack developer portfolio (MongoDB · Express · React · Node)",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix client install",
    "seed": "npm --prefix server run seed",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "build": "npm --prefix client run build",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
